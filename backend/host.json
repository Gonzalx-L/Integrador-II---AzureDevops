{
  "version": "2.0",
  "logging": {
    "applicationInsights": {
      "samplingSettings": {
        "isEnabled": true,
        "excludedTypes": "Request"
      }
    },
    "logLevel": {
      "default": "Information"
    }
  },
  "extensionBundle": {
    "id": "Microsoft.Azure.Functions.ExtensionBundle",
    "version": "[4.*, 5.0.0)"
  },
  "extensions": {
    "durableTask": {
      "hubName": "DocuColabTaskHub"
    }
  },
  "cors": {
    "allowedOrigins": [
      "http://localhost:5173",
      "http://localhost:4173",
      "https://func-docucolab-dev.azurewebsites.net"
    ],
    "supportCredentials": false
  }
}
